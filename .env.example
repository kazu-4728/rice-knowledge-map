# Supabase接続用の環境変数（このファイルは見本。実際の値は書かないこと）
#
# 取得場所: Supabase ダッシュボード → Project Settings → API Keys
#   - NEXT_PUBLIC_SUPABASE_URL: プロジェクトURL
#   - NEXT_PUBLIC_SUPABASE_ANON_KEY: publishableキー（sb_publishable_... 形式）
#
# 設定方法:
#   - ローカル開発: このファイルをコピーして .env.local を作成し、実際の値を記入する
#     （.env.local は .gitignore 済み。Gitにコミットされない）
#   - Vercel: ダッシュボードの Environment Variables に設定する
#
# 未設定の場合、アプリはサンプルデータのデモモードで動作する。
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# （任意）SupabaseでGoogleプロバイダを設定したら "1" にするとGoogleログインボタンが出る
NEXT_PUBLIC_ENABLE_GOOGLE_LOGIN=
